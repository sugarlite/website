---
import { APP_LINKS } from '@/constants';
import { t, translations } from '@/i18n';
import { getLocalizedPath } from '@/i18n/routing';
import type { Language } from '@/types';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const stories = (translations[lang].stories?.items as Array<{
  name: string;
  condition: string;
  location: string;
  avatar: string;
  paragraphs: string[];
  results?: string;
  quote?: string;
}>) || [];

const stats = (translations[lang].stories?.stats as Array<{ value: string; label: string }>) || [];

const CTA_FEATURES: Record<Language, string[]> = {
  zh: ['血糖趋势追踪', '饮食记录管理', '血糖指数', 'AI 智能洞察', '运动记录', '云端同步'],
  'zh-Hant': ['血糖趨勢追蹤', '飲食記錄管理', '血糖指數', 'AI 智能洞察', '運動記錄', '雲端同步'],
  en: ['Glucose Tracking', 'Food Logging', 'Glucose Index', 'AI Insights', 'Exercise Tracking', 'Cloud Sync'],
  ja: ['血糖トレンド追跡', '食事記録管理', '血糖指数', 'AIインサイト', '運動記録', 'クラウド同期'],
};
const CTA_TAGLINE: Record<Language, string> = {
  zh: '智能血糖监测与健康管理',
  'zh-Hant': '智能血糖監測與健康管理',
  en: 'Smart Blood Sugar Monitoring & Health Management',
  ja: 'スマート血糖モニタリングと健康管理',
};
const ctaFeatures = CTA_FEATURES[lang];
---

<style>
  :root {
    --w-prose: min(72ch, calc(100% - 2rem));
    --w-wide: 1600px;
    --gap-sm: 1.5rem;
    --gap-md: 3rem;
    --gap-lg: 5rem;
  }

  /* Page Header */
  .page-header {
    padding-top: calc(64px + 3rem);
    padding-bottom: var(--gap-md);
    max-width: var(--w-prose);
    width: 90%;
    margin: 0 auto;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-slate-500);
    margin-bottom: 2rem;
    transition: color 0.15s;
  }
  :global(.dark) .back-link {
    color: var(--color-slate-400);
  }
  .back-link:hover {
    color: var(--color-brand);
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--color-slate-900);
    margin-bottom: 0.75rem;
  }
  :global(.dark) .page-title {
    color: var(--color-white);
  }
  .page-subtitle {
    font-size: 1rem;
    color: var(--color-slate-500);
    max-width: 48ch;
  }
  :global(.dark) .page-subtitle {
    color: var(--color-slate-400);
  }

  /* Stats Banner */
  .stats-banner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    max-width: var(--w-wide);
    width: calc(100% - 2rem);
    margin: 0 auto var(--gap-lg);
    border-top: 1px solid var(--color-slate-200);
    border-bottom: 1px solid var(--color-slate-200);
  }
  :global(.dark) .stats-banner {
    border-color: var(--color-slate-700);
  }
  .stat-cell {
    text-align: center;
    padding: var(--gap-sm) 1rem;
    border-right: 1px solid var(--color-slate-200);
  }
  :global(.dark) .stat-cell {
    border-color: var(--color-slate-700);
  }
  .stat-cell:last-child {
    border-right: none;
  }
  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-brand);
    margin-bottom: 0.25rem;
  }
  .stat-desc {
    font-size: 0.78rem;
    color: var(--color-slate-500);
    letter-spacing: 0.02em;
  }
  :global(.dark) .stat-desc {
    color: var(--color-slate-400);
  }

  @media (max-width: 640px) {
    .stats-banner {
      grid-template-columns: repeat(2, 1fr);
    }
    .stat-cell {
      border-bottom: 1px solid var(--color-slate-200);
    }
    :global(.dark) .stat-cell {
      border-color: var(--color-slate-700);
    }
    .stat-cell:nth-child(3),
    .stat-cell:nth-child(4) {
      border-bottom: none;
    }
    .stat-cell:nth-child(2) {
      border-right: none;
    }
  }

  /* Story Cards */
  .stories-list {
    max-width: var(--w-prose);
    width: 90%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }
  .story-card {
    padding: var(--gap-md) 0;
    border-bottom: 1px solid var(--color-slate-200);
  }
  :global(.dark) .story-card {
    border-color: var(--color-slate-700);
  }
  .story-card:last-child {
    border-bottom: none;
  }

  .story-author {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .story-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .story-author-info {}
  .story-name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--color-slate-900);
    margin-bottom: 0.15rem;
  }
  :global(.dark) .story-name {
    color: var(--color-white);
  }
  .story-condition {
    font-size: 0.82rem;
    color: var(--color-brand);
    font-weight: 500;
    margin-bottom: 0.1rem;
  }
  .story-location {
    font-size: 0.75rem;
    color: var(--color-slate-500);
    letter-spacing: 0.02em;
  }
  :global(.dark) .story-location {
    color: var(--color-slate-400);
  }

  .story-text {
    margin-bottom: 1.25rem;
  }
  .story-text p {
    font-size: 0.92rem;
    color: var(--color-slate-700);
    line-height: 1.7;
    margin-bottom: 0.75rem;
    text-wrap: pretty;
  }
  :global(.dark) .story-text p {
    color: var(--color-slate-300);
  }
  .story-text p:last-child {
    margin-bottom: 0;
  }

  .story-results {
    margin-bottom: 1.25rem;
    padding: 0.85rem 1.15rem;
    border-left: 2px solid var(--color-brand);
    font-size: 0.88rem;
    color: var(--color-slate-700);
    line-height: 1.5;
  }
  :global(.dark) .story-results {
    color: var(--color-slate-300);
  }

  .story-quote {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 400;
    line-height: 1.35;
    letter-spacing: -0.01em;
    font-style: italic;
    color: var(--color-slate-500);
  }
  :global(.dark) .story-quote {
    color: var(--color-slate-400);
  }

  /* CTA */
  .cta-section {
    max-width: min(72ch, calc(100% - 2rem));
    width: 90%; margin: 0 auto;
    padding: 2rem 0;
    border-top: 1px solid var(--color-slate-200);
  }
  :global(.dark) .cta-section { border-color: var(--color-slate-700); }
  .cta-card { display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; }
  .cta-brand { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }
  .cta-icon {
    width: 52px; height: 52px; border-radius: 12px; flex-shrink: 0;
    box-shadow: 0 2px 12px -4px rgba(0, 192, 154, 0.3);
  }
  .cta-name {
    font-family: var(--font-display);
    font-size: 1.3rem; font-weight: 400; letter-spacing: -0.015em;
    color: var(--color-slate-900); margin-bottom: 0.15rem;
  }
  :global(.dark) .cta-name { color: var(--color-white); }
  .cta-tagline { font-size: 0.78rem; color: var(--color-slate-500); letter-spacing: 0.02em; }
  :global(.dark) .cta-tagline { color: var(--color-slate-400); }
  .cta-pills { flex: 1; min-width: 220px; display: flex; flex-wrap: wrap; gap: 0.4rem 0.75rem; }
  .cta-pill {
    font-size: 0.75rem; font-weight: 500; letter-spacing: 0.03em;
    color: var(--color-slate-500); white-space: nowrap; padding: 0.3rem 0;
  }
  :global(.dark) .cta-pill { color: var(--color-slate-400); }
  .cta-pill::before { content: '\2014'; margin-right: 0.35rem; color: #00C09A; }
  .cta-dl {
    flex-shrink: 0; display: inline-flex; align-items: center; gap: 0.45rem;
    font-size: 0.88rem; font-weight: 600; letter-spacing: 0.01em;
    padding: 0.65rem 1.5rem;
    background: var(--color-slate-900); color: var(--color-white);
    transition: opacity 0.2s; text-decoration: none;
  }
  :global(.dark) .cta-dl { background: var(--color-white); color: var(--color-slate-900); }
  .cta-dl:hover { opacity: 0.85; }
  @media (max-width: 600px) {
    .cta-card { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
    .cta-pills { flex-direction: column; gap: 0.2rem; }
  }
</style>

<!-- Page Header -->
<div class="page-header">
  <a href={getLocalizedPath(lang, '')} class="back-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    {t(lang, 'stories.backToHome')}
  </a>
  <h1 class="page-title">{t(lang, 'stories.title')}</h1>
  <p class="page-subtitle">{t(lang, 'stories.subtitle')}</p>
</div>

<!-- Stats Banner -->
<div class="stats-banner">
  {
    stats.map((stat) => (
      <div class="stat-cell">
        <p class="stat-value">{stat.value}</p>
        <p class="stat-desc">{stat.label}</p>
      </div>
    ))
  }
</div>

<!-- Stories -->
<main class="stories-list">
  {
    stories.map((story) => (
      <article class="story-card">
        <div class="story-author">
          <img src={story.avatar} alt={story.name} class="story-avatar" width="56" height="56" />
          <div class="story-author-info">
            <p class="story-name">{story.name}</p>
            <p class="story-condition">{story.condition}</p>
            <p class="story-location">{story.location}</p>
          </div>
        </div>
        <div class="story-text">
          {story.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
        {story.results && (
          <div class="story-results">{story.results}</div>
        )}
        {story.quote && (
          <p class="story-quote">"{story.quote}"</p>
        )}
      </article>
    ))
  }
</main>

<!-- Community CTA -->
<section class="cta-section">
  <div class="cta-card">
    <div class="cta-brand">
      <img src="/icon.png" alt="SugarLite" class="cta-icon" width="52" height="52" />
      <div>
        <p class="cta-name">SugarLite</p>
        <p class="cta-tagline">{CTA_TAGLINE[lang]}</p>
      </div>
    </div>
    <div class="cta-pills">
      {ctaFeatures.map((f) => <span class="cta-pill">{f}</span>)}
    </div>
    <a href={APP_LINKS.appStore} class="cta-dl">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
      {t(lang, 'stories.communityButton')}
    </a>
  </div>
</section>
