---
import { t } from '@/i18n';
import type { Language } from '@/types';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section class="border-t border-slate-200 dark:border-slate-800">
  <div class="max-w-[1600px] mx-auto px-[clamp(1rem,3vw,2rem)] text-center py-12">
    <div class="reveal stagger-1 grid grid-cols-2 md:grid-cols-4 gap-12">
      <div>
        <p class="font-display text-[clamp(2rem,4vw,3.25rem)] font-normal leading-[1.1] tracking-[-0.025em] text-slate-900 dark:text-white mb-[0.3rem]">5,000,000+</p>
        <p class="text-[0.82rem] text-slate-500 dark:text-slate-400 tracking-[0.02em]">{t(lang, 'stats.users')}</p>
      </div>
      <div>
        <p class="font-display text-[clamp(2rem,4vw,3.25rem)] font-normal leading-[1.1] tracking-[-0.025em] text-slate-900 dark:text-white mb-[0.3rem]">10,000+</p>
        <p class="text-[0.82rem] text-slate-500 dark:text-slate-400 tracking-[0.02em]">{t(lang, 'stats.food')}</p>
      </div>
      <div>
        <p class="font-display text-[clamp(2rem,4vw,3.25rem)] font-normal leading-[1.1] tracking-[-0.025em] text-slate-900 dark:text-white mb-[0.3rem]">4.9/5</p>
        <p class="text-[0.82rem] text-slate-500 dark:text-slate-400 tracking-[0.02em]">{t(lang, 'stats.ratings')}</p>
      </div>
      <div>
        <p class="font-display text-[clamp(2rem,4vw,3.25rem)] font-normal leading-[1.1] tracking-[-0.025em] text-slate-900 dark:text-white mb-[0.3rem]">24/7</p>
        <p class="text-[0.82rem] text-slate-500 dark:text-slate-400 tracking-[0.02em]">{t(lang, 'stats.availability')}</p>
      </div>
    </div>
  </div>
</section>
