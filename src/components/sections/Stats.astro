---
import { t } from '@/i18n';
import type { Language } from '@/types';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section class="py-20 bg-[#f5f5f7] dark:bg-[#0d0d0f]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 text-center">
      <div class="reveal stagger-1">
        <div class="text-4xl lg:text-5xl font-extrabold mb-2 text-slate-900 dark:text-white">5,000,000+</div>
        <div class="text-sm text-slate-500 dark:text-slate-400">{t(lang, 'stats.users')}</div>
      </div>
      <div class="reveal stagger-2">
        <div class="text-4xl lg:text-5xl font-extrabold mb-2 text-slate-900 dark:text-white">10,000+</div>
        <div class="text-sm text-slate-500 dark:text-slate-400">{t(lang, 'stats.food')}</div>
      </div>
      <div class="reveal stagger-3">
        <div class="text-4xl lg:text-5xl font-extrabold mb-2 text-slate-900 dark:text-white">4.9/5</div>
        <div class="text-sm text-slate-500 dark:text-slate-400">{t(lang, 'stats.ratings')}</div>
      </div>
      <div class="reveal stagger-4">
        <div class="text-4xl lg:text-5xl font-extrabold mb-2 text-slate-900 dark:text-white">24/7</div>
        <div class="text-sm text-slate-500 dark:text-slate-400">{t(lang, 'stats.availability')}</div>
      </div>
    </div>
  </div>
</section>
