---
import { t } from '@/i18n';
import type { Language } from '@/types';
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import AppStoreBadge from './AppStoreBadge';

interface Props {
  lang: Language;
  entry: CollectionEntry<'blog'>;
}

const { lang, entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, updatedDate, cover, relatedSlugs } = entry.data;

const allEntries = await getCollection('blog');

function findEntry(slug: string, language: Language) {
  return allEntries.find((e) => e.id === `${slug}-${language.toLowerCase()}`);
}

const relatedEntries = (relatedSlugs || [])
  .map((slug) => findEntry(slug, lang))
  .filter(Boolean) as CollectionEntry<'blog'>[];

const formattedDate = new Date(updatedDate).toLocaleDateString(
  lang === 'en' ? 'en-US' : lang === 'ja' ? 'ja-JP' : 'zh-CN',
  {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }
);

// Category labels for each language
const CATEGORY: Record<Language, string> = {
  zh: '血糖管理',
  'zh-Hant': '血糖管理',
  en: 'Blood Sugar',
  ja: '血糖管理',
};

// Byline / author labels
const AUTHOR_NAME: Record<Language, string> = {
  zh: 'SugarLite 团队',
  'zh-Hant': 'SugarLite 團隊',
  en: 'SugarLite Team',
  ja: 'SugarLite チーム',
};

const AUTHOR_BIO: Record<Language, string> = {
  zh: '致力于用科技让血糖管理更简单、更智能。',
  'zh-Hant': '致力於用科技讓血糖管理更簡單、更智能。',
  en: 'Making blood sugar management simpler and smarter with technology.',
  ja: 'テクノロジーで血糖管理をもっとシンプルに、もっとスマートに。',
};
---

<div class="blog-post">
  <div class="article-wrap">
    <!-- ===== Article Header ===== -->
    <header class="article-header">
      <p class="eyebrow">{CATEGORY[lang]}</p>
      <h1 class="headline">{title}</h1>
      {
        description && (
          <p class="deck">{description}</p>
        )
      }
      <p class="byline">
        <strong>{AUTHOR_NAME[lang]}</strong> · {formattedDate}
      </p>
    </header>

    <!-- ===== Hero Image ===== -->
    <figure class="hero">
      {
        cover ? (
          <>
            <img src={cover} alt={title} class="hero-img" loading="eager" />
            <figcaption class="caption">{title}</figcaption>
          </>
        ) : (
          <>
            <div class="hero-placeholder"></div>
            <figcaption class="caption">{title}</figcaption>
          </>
        )
      }
    </figure>

    <!-- ===== Body ===== -->
    <div class="post-content">
      <Content />
    </div>

    <!-- ===== Author Footer ===== -->
    <footer class="author-footer">
      <div class="author-avatar" aria-hidden="true">
        {lang === 'ja' ? 'S' : 'S'}
      </div>
      <div>
        <p class="author-name">{AUTHOR_NAME[lang]}</p>
        <p class="author-bio">{AUTHOR_BIO[lang]}</p>
      </div>
    </footer>

    <!-- ===== Related Reading ===== -->
    {
      relatedEntries.length > 0 && (
        <section class="related">
          <h3>{t(lang, 'blog.relatedReading')}</h3>
          <div class="related-grid">
            {
              relatedEntries.map((related) => {
                const relatedSlug = related.id.replace(new RegExp(`-${lang.toLowerCase()}$`), '');
                return (
                  <a href={`/${lang}/blog/${relatedSlug}`} class="related-card">
                    <div class="related-thumb">
                      {related.data.cover && (
                        <img src={related.data.cover} alt={related.data.title} class="related-thumb-img" loading="lazy" />
                      )}
                    </div>
                    <p class="related-meta">{related.data.updatedDate}</p>
                    <p class="related-title">{related.data.title}</p>
                    {
                      related.data.excerpt && (
                        <p class="related-excerpt">{related.data.excerpt}</p>
                      )
                    }
                  </a>
                );
              })
            }
          </div>
        </section>
      )
    }

    <!-- ===== CTA Section ===== -->
    <section class="cta-section">
      <h2 class="cta-title">{t(lang, 'blog.ctaTitle')}</h2>
      <p class="cta-text">{t(lang, 'blog.ctaSubtitle')}</p>
      <div class="cta-action">
        <AppStoreBadge client:load lang={lang} />
      </div>
    </section>
  </div>
</div>

<style>
  /* ===== Blog-specific tokens ===== */
  .blog-post {
    --bg:      oklch(98% 0.004 95);
    --surface: oklch(100% 0.002 95);
    --fg:      oklch(20% 0.018 70);
    --muted:   oklch(48% 0.012 70);
    --border:  oklch(90% 0.006 95);
    --accent:  oklch(70% 0.15 170);

    --font-display: 'Iowan Old Style', 'Charter', Georgia, 'Noto Serif SC', serif;
    --font-body:    'Outfit', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;

    --measure: min(75rem, calc(100% - 2rem));
    --gap-sm: 2rem;
    --gap-md: 4rem;
    --gap-lg: 6rem;
  }

  /* ===== Article Wrapper ===== */
  .article-wrap {
    max-width: var(--measure);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ===== Article Header ===== */
  .article-header {
    padding-top: clamp(4rem, 8vw, 7rem);
    padding-bottom: var(--gap-md);
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.25rem;
  }

  .headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.25rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--fg);
    text-wrap: balance;
    margin-bottom: 1.5rem;
  }

  .deck {
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    line-height: 1.55;
    color: var(--muted);
  }

  .byline {
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .byline strong {
    color: var(--fg);
    font-weight: 600;
  }

  /* ===== Hero ===== */
  .hero {
    margin-bottom: var(--gap-lg);
  }

  .hero-img {
    width: 100%;
    border-radius: 2px;
    display: block;
  }

  .hero-placeholder {
    aspect-ratio: 16 / 9;
    border-radius: 2px;
    background: linear-gradient(135deg, oklch(85% 0.06 170), oklch(90% 0.04 180), oklch(95% 0.02 160));
    position: relative;
    overflow: hidden;
  }

  .hero-placeholder::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 50% at 30% 50%, oklch(75% 0.12 170 / 0.3), transparent);
  }

  .caption {
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.01em;
    margin-top: 0.6rem;
  }

  /* ===== Post Content (avoid conflict with Tailwind `.prose`) ===== */
  .post-content {
    padding-bottom: var(--gap-lg);
  }

  .post-content :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 1.85rem);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: var(--fg);
    margin-top: var(--gap-lg);
    margin-bottom: 0.5rem;
  }

  .post-content :global(h2:first-of-type) {
    margin-top: 0;
  }

  .post-content :global(p) {
    margin-bottom: 1.35rem;
    text-align: start;
    text-wrap: pretty;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--fg);
  }

  .post-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .post-content :global(strong) {
    font-weight: 600;
  }

  .post-content :global(ul) {
    margin: 1.5rem 0 2rem;
    padding-inline-start: 1.5rem;
    list-style: none;
  }

  .post-content :global(ul li) {
    position: relative;
    margin-bottom: 0.65rem;
    padding-inline-start: 1.25rem;
    line-height: 1.6;
  }

  .post-content :global(ul li::before) {
    content: '—';
    position: absolute;
    inset-inline-start: 0;
    color: var(--muted);
  }

  .post-content :global(blockquote) {
    margin: var(--gap-lg) 0;
    padding-inline-start: 1.25rem;
    border-inline-start: 3px solid var(--accent);
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.15rem);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--fg);
    max-width: 42ch;
  }

  .post-content :global(blockquote p) {
    margin-bottom: 0;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    letter-spacing: inherit;
    color: inherit;
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: 2px;
    margin: var(--gap-md) 0;
    display: block;
  }

  .post-content :global(em) {
    font-style: italic;
  }

  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-content :global(a:hover) {
    opacity: 0.8;
  }

  /* ===== Author Footer ===== */
  .author-footer {
    margin-top: var(--gap-lg);
    padding-top: var(--gap-md);
    border-top: 1px solid var(--border);
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .author-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: oklch(85% 0.06 170);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--surface);
    letter-spacing: 0.04em;
  }

  .author-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--fg);
    margin-bottom: 0.2rem;
  }

  .author-bio {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.55;
  }

  /* ===== Related Reading ===== */
  .related {
    margin-top: var(--gap-lg);
    padding-top: var(--gap-md);
    border-top: 1px solid var(--border);
  }

  .related h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin-bottom: 1.5rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .related-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .related-card:hover .related-title {
    color: var(--accent);
  }

  .related-thumb {
    aspect-ratio: 3 / 2;
    background: oklch(94% 0.008 170);
    margin-bottom: 0.75rem;
    border-radius: 2px;
    overflow: hidden;
  }

  .related-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .related-meta {
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }

  .related-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: -0.005em;
    color: var(--fg);
    transition: color 0.2s;
    margin-bottom: 0.3rem;
  }

  .related-excerpt {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ===== CTA Section ===== */
  .cta-section {
    margin-top: var(--gap-lg);
    padding-top: var(--gap-md);
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin-bottom: 0.75rem;
  }

  .cta-text {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.55;
    max-width: 40ch;
    margin: 0 auto 1.5rem;
  }

  .cta-action {
    display: flex;
    justify-content: center;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .related-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .blog-post {
      --gap-sm: 1.25rem;
      --gap-md: 2rem;
      --gap-lg: 3rem;
    }
    .article-wrap {
      padding: 0 1.25rem;
    }
    .related-grid {
      grid-template-columns: 1fr;
    }
    .headline {
      font-size: 2rem;
    }
  }
</style>
