---
import AppStoreCard from './AppStoreCard';
import { APP_LINKS } from '@/constants';
import { t } from '@/i18n';
import type { Language } from '@/types';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section id="download" class="py-32 bg-[#f5f5f7] dark:bg-[#0d0d0f]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14 space-y-4">
      <h2 class="reveal stagger-1 text-4xl lg:text-5xl font-extrabold text-slate-900 dark:text-white">
        {t(lang, 'cta.title')}
      </h2>
      <p class="reveal stagger-2 text-lg text-slate-500 dark:text-slate-400 max-w-xl mx-auto">
        {t(lang, 'cta.subtitle')}
      </p>
    </div>

    <div class="reveal stagger-3 flex flex-col lg:flex-row items-center justify-center gap-8 lg:gap-12">
      <!-- App Store Card - dynamically fetches icon, description, ratings from iOS -->
      <div class="w-full max-w-md">
        <AppStoreCard client:load lang={lang} />
      </div>

      <!-- Help link -->
      <div class="flex flex-col items-center gap-5">
        <a
          href={APP_LINKS.supportUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 hover:text-brand dark:hover:text-brand transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {t(lang, 'hero.helpCenter')}
        </a>
      </div>
    </div>
  </div>
</section>
