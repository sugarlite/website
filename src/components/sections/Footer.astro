---
import { APP_NAME } from '@/constants';
import { t } from '@/i18n';
import type { Language } from '@/types';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<footer class="border-t border-slate-200 dark:border-slate-800 py-12">
  <div class="max-w-[1600px] mx-auto px-[clamp(1rem,3vw,2rem)]">
    <div class="flex flex-col sm:flex-row justify-between items-center flex-wrap gap-6 text-[0.8rem] text-slate-500 dark:text-slate-400 tracking-[0.02em]">
      <span>© 2026 SugarLite {APP_NAME[lang]} — {t(lang, 'footer.tagline')}</span>
      <span class="flex flex-wrap justify-center gap-x-1 gap-y-2 text-[0.8rem] text-slate-500 dark:text-slate-400 tracking-[0.02em]">
        <a href={`/${lang}/privacy`} class="hover:text-brand transition-colors">{t(lang, 'nav.privacy')}</a>
        <span>&nbsp;·&nbsp;</span>
        <a href={`/${lang}/terms`} class="hover:text-brand transition-colors">{t(lang, 'nav.terms')}</a>
        <span>&nbsp;·&nbsp;</span>
        <a href={`/${lang}/faq`} class="hover:text-brand transition-colors">{t(lang, 'nav.faq')}</a>
        <span>&nbsp;·&nbsp;</span>
        <a href={`/${lang}/blog`} class="hover:text-brand transition-colors">{t(lang, 'nav.blog')}</a>
      </span>
    </div>
  </div>
</footer>
