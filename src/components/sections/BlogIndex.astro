---
import { t } from '@/i18n';
import type { Language } from '@/types';
import { getCollection } from 'astro:content';
import AppStoreBadge from './AppStoreBadge';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const allEntries = await getCollection('blog');

const posts = allEntries
  .filter((entry) => entry.id.endsWith(`-${lang.toLowerCase()}`))
  .map((entry) => {
    const slug = entry.id.replace(new RegExp(`-${lang.toLowerCase()}$`), '');
    return {
      slug,
      ...entry.data,
    };
  })
  .sort((a, b) => b.updatedDate.localeCompare(a.updatedDate));
---

<div class="blog-index">
  <div class="index-wrap">
    <!-- ===== Header ===== -->
    <header class="index-header">
      <div class="index-header-inner">
        <p class="index-badge">Blog</p>
        <h1 class="index-title">{t(lang, 'blog.title')}</h1>
        <p class="index-description">{t(lang, 'blog.subtitle')}</p>
      </div>
    </header>

    <!-- ===== Posts Grid ===== -->
    {
      posts.length > 0 && (
        <section class="post-list">
          <div class="post-grid">
            {
              posts.map((post) => (
                <article class="post-card">
                  <a href={`/${lang}/blog/${post.slug}`} class="post-card-link">
                    <div class="post-card-thumb">
                      {
                        post.cover ? (
                          <img src={post.cover} alt={post.title} class="post-card-img" loading="lazy" />
                        ) : (
                          <div class="post-card-placeholder"></div>
                        )
                      }
                    </div>
                    <div class="post-card-body">
                      <p class="post-card-meta">{t(lang, 'blog.updatedOn')}: {post.updatedDate}</p>
                      <h2 class="post-card-title">{post.title}</h2>
                      {
                        post.excerpt && (
                          <p class="post-card-excerpt">{post.excerpt}</p>
                        )
                      }
                      <span class="post-card-link-text">
                        {t(lang, 'blog.readMore')}
                        <svg class="post-card-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                      </span>
                    </div>
                  </a>
                </article>
              ))
            }
          </div>
        </section>
      )
    }

    <!-- ===== CTA Section ===== -->
    <section class="cta-section">
      <h2 class="cta-title">{t(lang, 'blog.ctaTitle')}</h2>
      <p class="cta-text">{t(lang, 'blog.ctaSubtitle')}</p>
      <div class="cta-action">
        <AppStoreBadge client:load lang={lang} />
      </div>
    </section>
  </div>
</div>

<style>
  /* ===== Tokens ===== */
  .blog-index {
    --bg:      oklch(98% 0.004 95);
    --surface: oklch(100% 0.002 95);
    --fg:      oklch(20% 0.018 70);
    --muted:   oklch(48% 0.012 70);
    --border:  oklch(90% 0.006 95);
    --accent:  oklch(70% 0.15 170);

    --font-display: 'Iowan Old Style', 'Charter', Georgia, 'Noto Serif SC', serif;
    --font-body:    'Outfit', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;

    --gap-sm: 1.5rem;
    --gap-md: 3rem;
    --gap-lg: 5rem;
  }

  /* ===== Wrapper ===== */
  .index-wrap {
    max-width: min(1600px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ===== Index Header ===== */
  .index-header {
    padding-top: clamp(4rem, 8vw, 7rem);
    padding-bottom: var(--gap-lg);
  }

  .index-header-inner {
    max-width: 85ch;
  }

  .index-badge {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .index-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5.5vw, 4.5rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--fg);
    text-wrap: balance;
    margin-bottom: 1rem;
  }

  .index-description {
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    line-height: 1.55;
    color: var(--muted);
  }

  /* ===== Posts Grid ===== */
  .post-list {
    padding-bottom: var(--gap-lg);
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }

  /* ===== Post Card ===== */
  .post-card {
    border-bottom: 1px solid var(--border);
  }

  .post-card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .post-card-thumb {
    aspect-ratio: 16 / 9;
    background: oklch(94% 0.008 170);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .post-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.3s ease;
  }

  .post-card-link:hover .post-card-img {
    opacity: 0.85;
  }

  .post-card-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, oklch(85% 0.06 170), oklch(92% 0.04 180));
  }

  .post-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .post-card-meta {
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-bottom: 0.35rem;
  }

  .post-card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin-bottom: 0.5rem;
    transition: color 0.2s;
  }

  .post-card-link:hover .post-card-title {
    color: var(--accent);
  }

  .post-card-excerpt {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.55;
    flex: 1;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-link-text {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
    transition: gap 0.2s;
  }

  .post-card-link:hover .post-card-link-text {
    gap: 0.6rem;
  }

  .post-card-arrow {
    transition: transform 0.2s;
  }

  .post-card-link:hover .post-card-arrow {
    transform: translateX(3px);
  }

  /* ===== CTA Section ===== */
  .cta-section {
    padding-top: var(--gap-lg);
    padding-bottom: var(--gap-lg);
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin-bottom: 0.75rem;
  }

  .cta-text {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.55;
    max-width: 40ch;
    margin: 0 auto 1.5rem;
  }

  .cta-action {
    display: flex;
    justify-content: center;
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .post-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media (max-width: 600px) {
    .blog-index {
      --gap-sm: 1.25rem;
      --gap-md: 2rem;
      --gap-lg: 3rem;
    }
    .index-wrap {
      padding: 0 1.25rem;
    }
    .post-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .index-title {
      font-size: 2rem;
    }
  }
</style>
