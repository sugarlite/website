---
import { t, translations } from '@/i18n';
import type { Language } from '@/types';
import { APP_LINKS } from '@/constants';
import { getCollection } from 'astro:content';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const allEntries = await getCollection('blog');

const posts = allEntries
  .filter((entry) => entry.id.endsWith(`-${lang.toLowerCase()}`))
  .map((entry) => {
    const slug = entry.id.replace(new RegExp(`-${lang.toLowerCase()}$`), '');
    return {
      slug,
      ...entry.data,
    };
  })
  .sort((a, b) => b.updatedDate.localeCompare(a.updatedDate));
---

<div class="min-h-screen bg-white dark:bg-slate-950 pt-32 pb-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Back Button -->
    <a
      href={`/${lang}`}
      class="text-brand hover:text-brand-dark transition-colors mb-8 flex items-center gap-2"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      {t(lang, 'blog.backToBlog')}
    </a>

    <!-- Header -->
    <div class="mb-16 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 dark:text-white">
        {t(lang, 'blog.title')}
      </h1>
      <p class="text-lg text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">
        {t(lang, 'blog.subtitle')}
      </p>
    </div>

    <!-- Posts Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
      {
        posts.map((post) => (
          <article class="group bg-slate-50 dark:bg-slate-900 rounded-2xl overflow-hidden hover:shadow-xl transition-all duration-300 flex flex-col h-full">
            <a href={`/${lang}/blog/${post.slug}`} class="block flex flex-col h-full">
              <div class="aspect-[16/9] bg-brand/10 flex items-center justify-center overflow-hidden">
                {post.cover ? (
                  <img
                    src={post.cover}
                    alt={post.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-16 h-16 rounded-2xl bg-brand/20 flex items-center justify-center">
                    <svg
                      class="w-8 h-8 text-brand"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"
                      />
                    </svg>
                  </div>
                )}
              </div>
              <div class="p-6 flex flex-col flex-1">
                <div class="text-xs font-medium text-brand mb-2">
                  {t(lang, 'blog.updatedOn')}: {post.updatedDate}
                </div>
                <h2 class="text-xl font-bold mb-3 dark:text-white group-hover:text-brand transition-colors line-clamp-2">
                  {post.title}
                </h2>
                <p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed mb-4 flex-1 line-clamp-3">
                  {post.excerpt}
                </p>
                <span class="inline-flex items-center text-brand font-semibold text-sm">
                  {t(lang, 'blog.readMore')}
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"
                    />
                  </svg>
                </span>
              </div>
            </a>
          </article>
        ))
      }
    </div>

    <!-- CTA -->
    <div class="bg-gradient-to-br from-brand/10 to-emerald-500/10 rounded-3xl p-8 md:p-12 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4 dark:text-white">
        {t(lang, 'blog.ctaTitle')}
      </h2>
      <p class="text-slate-600 dark:text-slate-300 mb-8 max-w-xl mx-auto">
        {t(lang, 'blog.ctaSubtitle')}
      </p>
      <a
        href={APP_LINKS.appStore}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-brand text-white px-8 py-3 rounded-full font-bold hover:bg-brand-dark transition-colors"
      >
        {t(lang, 'blog.downloadButton')}
      </a>
    </div>
  </div>
</div>
