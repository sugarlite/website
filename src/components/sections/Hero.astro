---
import AppStoreBadge from './AppStoreBadge';
import { APP_LINKS } from '@/constants';
import { t } from '@/i18n';
import type { Language } from '@/types';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section class="overflow-hidden relative hero-section" style="padding-top: calc(64px + clamp(3rem, 10vw, 8rem)); padding-bottom: 8rem; background: linear-gradient(180deg, #ecfdf5 0%, #f0fdfa 15%, #ffffff 45%, #f8fafc 100%);">
  <!-- Ambient glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true" style="background: radial-gradient(ellipse 70% 50% at 75% 15%, rgba(0, 192, 154, 0.08), transparent 55%), radial-gradient(ellipse 50% 40% at 25% 85%, rgba(0, 192, 154, 0.05), transparent 55%);"></div>
  <div class="max-w-[1600px] mx-auto px-[clamp(1rem,3vw,2rem)] relative">
    <div class="grid grid-cols-1 lg:grid-cols-[1.15fr_1fr] items-center gap-[clamp(2rem,6vw,6rem)]">
      <!-- Text column -->
      <div class="max-w-[56ch] lg:text-left text-center mx-auto lg:mx-0">
        <p class="reveal text-[0.72rem] font-medium tracking-[0.08em] uppercase text-brand mb-3">
          {t(lang, 'hero.tag')}
        </p>
        <h1 class="reveal stagger-1 font-display text-[clamp(2.6rem,7vw,5.25rem)] font-normal leading-[1.03] tracking-[-0.035em] text-slate-900 dark:text-white text-balance mb-5 whitespace-nowrap">
          {t(lang, 'hero.title')}<br />
          <em class="italic text-brand">{t(lang, 'hero.titleHighlight')}</em>
        </h1>
        <p class="reveal stagger-2 text-[clamp(1rem,1.8vw,1.15rem)] text-slate-500 dark:text-slate-400 leading-relaxed max-w-[46ch] mb-8">
          {t(lang, 'hero.subtitle')}
        </p>
        <div class="reveal stagger-3 flex flex-wrap gap-3 justify-center lg:justify-start mb-6">
          <span class="inline-block text-[0.78rem] font-medium tracking-[0.03em] px-4 py-[0.35rem] border border-slate-300 dark:border-slate-600 text-slate-500 dark:text-slate-400">{t(lang, 'hero.badgeGlucoseIndex')}</span>
          <span class="inline-block text-[0.78rem] font-medium tracking-[0.03em] px-4 py-[0.35rem] border border-slate-300 dark:border-slate-600 text-slate-500 dark:text-slate-400">{t(lang, 'hero.badgeAppleHealth')}</span>
          <span class="inline-block text-[0.78rem] font-medium tracking-[0.03em] px-4 py-[0.35rem] border border-slate-300 dark:border-slate-600 text-slate-500 dark:text-slate-400">{t(lang, 'hero.badgeAiInsights')}</span>
        </div>
        <div class="reveal stagger-4 flex flex-wrap gap-3 justify-center lg:justify-start">
          <AppStoreBadge client:load lang={lang} />
          <a
            href={APP_LINKS.supportUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-[0.95rem] font-medium tracking-[0.01em] px-8 py-3 border border-slate-300 dark:border-slate-600 text-slate-900 dark:text-white hover:border-brand hover:text-brand transition-colors"
          >
            {t(lang, 'hero.helpCenter')}
          </a>
        </div>
      </div>

        <!-- Phone visual -->
      <div class="relative flex items-center justify-center pt-8 lg:pt-0" aria-hidden="true">
        <div class="reveal stagger-2 relative w-[min(280px,72vw)] rounded-[3rem] bg-[#111] border-[3px] border-[#1a1a1e] overflow-hidden z-[2]" style="box-shadow: 0 30px 60px -30px rgba(0,0,0,0.35);">
          <picture>
            <source srcset="/hero-phone.avif" type="image/avif" />
            <source srcset="/hero-phone.webp" type="image/webp" />
            <img
              src="/hero-phone.png"
              alt="SugarLite App Interface"
              class="w-full h-auto block"
              width="470"
              height="1024"
              fetchpriority="high"
              loading="eager"
              decoding="async"
            />
          </picture>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:inline>
  .dark .hero-section {
    background: linear-gradient(180deg, #0f1a18 0%, #0f1724 25%, #020617 70%, #020617 100%) !important;
  }
  .dark .hero-section [aria-hidden] {
    background: none !important;
  }
  @media (max-width: 860px) {
    .hero-float-1 { right: 5% !important; }
    .hero-float-2 { left: 5% !important; }
  }
</style>
