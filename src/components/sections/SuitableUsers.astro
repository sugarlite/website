---
import { t, tArray } from '@/i18n';
import type { Language } from '@/types';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const users = tArray(lang, 'suitableFor.users');
---

<section class="border-t border-slate-200 dark:border-slate-800 py-32">
  <div class="max-w-[1600px] mx-auto px-[clamp(1rem,3vw,2rem)]">
    <div class="grid md:grid-cols-2 gap-20 items-start">
      <!-- Users list -->
      <div class="reveal stagger-1">
        <h2 class="font-display text-[clamp(1.8rem,4vw,3rem)] font-normal leading-[1.08] tracking-[-0.025em] text-slate-900 dark:text-white mb-6">
          {t(lang, 'suitableFor.title')}
        </h2>
        <ul class="list-none">
          {
            users.map((user, i) => (
              <li class={`${i > 0 ? '' : 'pt-0'} flex items-start gap-3 py-[0.8rem] border-b border-slate-200 dark:border-slate-700 text-[0.95rem] text-slate-900 dark:text-white leading-relaxed`}>
                <span class="w-[6px] h-[6px] rounded-full bg-brand mt-[0.55em] shrink-0" aria-hidden="true"></span>
                <span>{user}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Disclaimer -->
      <div class="reveal stagger-2">
        <h3 class="font-display text-2xl font-normal tracking-[-0.015em] text-slate-900 dark:text-white mb-3">
          {t(lang, 'disclaimer.title')}
        </h3>
        <p class="text-[0.9rem] text-slate-500 dark:text-slate-400 leading-relaxed">
          {t(lang, 'disclaimer.text')}
        </p>
      </div>
    </div>
  </div>
</section>
