---
import { t, tArray } from '@/i18n';
import type { Language } from '@/types';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const users = tArray(lang, 'suitableFor.users');
---

<section class="py-32 bg-white dark:bg-black">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16">
      <div>
        <h3 class="reveal stagger-1 text-4xl lg:text-5xl font-extrabold mb-8 text-slate-900 dark:text-white">
          {t(lang, 'suitableFor.title')}
        </h3>
        <ul class="space-y-4 text-lg text-slate-500 dark:text-slate-400">
          {
            users.map((user, i) => (
              <li class={`reveal stagger-${i + 2} flex items-start gap-3`}>
                <span class="text-brand mt-1.5 text-xs">●</span>
                <span>{user}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h3 class="reveal stagger-1 text-4xl lg:text-5xl font-extrabold mb-8 text-slate-900 dark:text-white">
          {t(lang, 'disclaimer.title')}
        </h3>
        <p class="reveal stagger-3 text-lg leading-relaxed text-slate-500 dark:text-slate-400">
          {t(lang, 'disclaimer.text')}
        </p>
      </div>
    </div>
  </div>
</section>
