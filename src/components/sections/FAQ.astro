---
import { t, translations } from '@/i18n';
import type { Language } from '@/types';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const faqs = (translations[lang].faq?.items as Array<{ q: string; a: string }>) || [];
---

<style>
  .page-header {
    padding-top: calc(64px + 3rem);
    padding-bottom: 3rem;
    max-width: min(72ch, calc(100% - 2rem));
    width: 90%; margin: 0 auto;
  }
  .back-link {
    display: inline-flex; align-items: center; gap: 0.35rem;
    font-size: 0.85rem; font-weight: 500; color: var(--color-slate-500);
    margin-bottom: 2rem; transition: color 0.15s;
  }
  :global(.dark) .back-link { color: var(--color-slate-400); }
  .back-link:hover { color: #00C09A; }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 400; line-height: 1.08; letter-spacing: -0.03em;
    color: var(--color-slate-900); margin-bottom: 0.75rem;
  }
  :global(.dark) .page-title { color: var(--color-white); }
  .page-subtitle {
    font-size: 1rem; color: var(--color-slate-500);
  }
  :global(.dark) .page-subtitle { color: var(--color-slate-400); }

  .page-content {
    max-width: min(72ch, calc(100% - 2rem));
    width: 90%; margin: 0 auto; padding-bottom: 5rem;
  }

  /* FAQ Accordion */
  .faq-list { display: flex; flex-direction: column; }
  .faq-item { border-top: 1px solid var(--color-slate-200); }
  :global(.dark) .faq-item { border-color: var(--color-slate-700); }
  .faq-item:last-child { border-bottom: 1px solid var(--color-slate-200); }
  :global(.dark) .faq-item:last-child { border-color: var(--color-slate-700); }
  .faq-btn {
    width: 100%; display: flex; align-items: flex-start; gap: 1rem;
    padding: 1.35rem 0; background: none; border: none; cursor: pointer;
    text-align: left; font-family: inherit; color: inherit;
  }
  .faq-btn:hover .faq-q { color: #00C09A; }
  .faq-num {
    font-family: var(--font-mono);
    font-size: 0.8rem; font-weight: 500; letter-spacing: 0.04em;
    color: var(--color-slate-500); min-width: 1.8rem; padding-top: 0.2em;
  }
  :global(.dark) .faq-num { color: var(--color-slate-400); }
  .faq-q {
    font-family: var(--font-display);
    font-size: 1.15rem; font-weight: 400; line-height: 1.35;
    letter-spacing: -0.01em; color: var(--color-slate-900);
    flex: 1; transition: color 0.2s;
  }
  :global(.dark) .faq-q { color: var(--color-white); }
  .faq-chevron {
    flex-shrink: 0; width: 20px; height: 20px; margin-top: 0.3em;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    color: var(--color-slate-500);
  }
  :global(.dark) .faq-chevron { color: var(--color-slate-400); }
  .faq-item.open .faq-chevron { transform: rotate(180deg); }

  .faq-answer {
    max-height: 0; overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .faq-item.open .faq-answer { max-height: 600px; }
  .faq-answer-inner {
    padding: 0 0 1.5rem 2.8rem;
    font-size: 0.92rem; color: var(--color-slate-500); line-height: 1.7;
  }
  :global(.dark) .faq-answer-inner { color: var(--color-slate-400); }

  /* CTA */
  .cta-section {
    margin-top: 5rem; padding-top: 3rem;
    border-top: 1px solid var(--color-slate-200); text-align: center;
  }
  :global(.dark) .cta-section { border-color: var(--color-slate-700); }
  .cta-section p {
    font-size: 0.9rem; color: var(--color-slate-500); margin-bottom: 1.25rem;
  }
  :global(.dark) .cta-section p { color: var(--color-slate-400); }
  .cta-section a {
    display: inline-block; font-size: 0.85rem; font-weight: 500;
    color: #00C09A; transition: opacity 0.2s;
  }
  .cta-section a:hover { opacity: 0.8; }
</style>

<div class="page-header">
  <a href={`/${lang}`} class="back-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    {t(lang, 'faq.backToHome')}
  </a>
  <h1 class="page-title">{t(lang, 'faq.title')}</h1>
  <p class="page-subtitle">{t(lang, 'faq.subtitle')}</p>
</div>

<main class="page-content">
  <div class="faq-list">
    {faqs.map((faq, i) => (
      <div class={`faq-item${i === 0 ? ' open' : ''}`}>
        <button class="faq-btn" aria-expanded={i === 0 ? 'true' : 'false'}>
          <span class="faq-num">{String(i + 1).padStart(2, '0')}</span>
          <span class="faq-q">{faq.q}</span>
          <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="faq-answer">
          <div class="faq-answer-inner">{faq.a}</div>
        </div>
      </div>
    ))}
  </div>

  <div class="cta-section">
    <p>{t(lang, 'faq.stillHaveQuestions')}</p>
    <a href="mailto:support@sugarlite.top">support@sugarlite.top</a>
  </div>
</main>

<script is:inline>
  (function () {
    document.querySelectorAll('.faq-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = btn.parentElement;
        var isOpen = item.classList.contains('open');
        item.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(!isOpen));
      });
    });
  })();
</script>
