---
import { APP_NAME, APP_LINKS } from '@/constants';
import { t } from '@/i18n';
import { getLocalizedPath } from '@/i18n/routing';
import type { Language } from '@/types';

interface AlternateUrl {
  lang: Language;
  href: string;
}

interface Props {
  lang: Language;
  alternateUrls: AlternateUrl[];
}

const { lang, alternateUrls } = Astro.props;

const LANG_LABELS: Record<Language, string> = {
  zh: '中文',
  en: 'English',
  ja: '日本語',
  'zh-Hant': '繁體中文',
};

const LANG_SHORT_LABELS: Record<Language, string> = {
  zh: '中',
  en: 'EN',
  ja: '日',
  'zh-Hant': '繁',
};
---

<nav
  id="site-navbar"
  class="fixed top-0 left-0 right-0 z-50 h-16 transition-shadow duration-300"
  style="background: rgba(255,255,255,0.82); -webkit-backdrop-filter: blur(20px) saturate(180%); backdrop-filter: blur(20px) saturate(180%);"
  data-lang={lang}
>
  <div class="max-w-[1600px] mx-auto px-[clamp(1rem,3vw,2rem)] h-full flex items-center justify-between">
    <!-- Brand -->
    <a href={getLocalizedPath(lang, '')} class="flex items-center gap-2.5 font-bold text-[1.1rem] tracking-[-0.01em] text-slate-900 dark:text-white">
      <img src="/icon.png" alt="SugarLite" class="w-8 h-8 rounded-lg shrink-0 object-contain" width="32" height="32" />
      {lang === 'en' ? 'SugarLite' : `${APP_NAME[lang]}`}
    </a>

    <!-- Desktop nav links -->
    <div class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-500 dark:text-slate-400">
      <a href={`${getLocalizedPath(lang, '')}#features`} class="hover:text-brand transition-colors">{t(lang, 'nav.features')}</a>
      <a href={`${getLocalizedPath(lang, '')}#preview`} class="hover:text-brand transition-colors">{t(lang, 'nav.preview')}</a>
      <a href={getLocalizedPath(lang, 'stories')} class="hover:text-brand transition-colors">{t(lang, 'nav.stories')}</a>
      <a href={getLocalizedPath(lang, 'blog')} class="hover:text-brand transition-colors">{t(lang, 'nav.blog')}</a>
    </div>

    <!-- Right side -->
    <div class="flex items-center gap-3">
      <!-- Language selector -->
      <div class="relative navbar-dropdown">
        <button class="flex items-center gap-1.5 h-9 px-2.5 border border-slate-300 dark:border-slate-600 bg-transparent cursor-pointer text-xs font-medium text-slate-500 dark:text-slate-400 tracking-[0.02em] hover:text-brand hover:border-brand transition-colors">
          {LANG_LABELS[lang]}
          <svg class="w-3 h-3 transition-transform dropdown-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="navbar-dropdown-menu hidden absolute top-[calc(100%+4px)] right-0 min-w-[120px] border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 z-50">
          {
            alternateUrls.map((alt) => (
              <a
                href={alt.href}
                class={`block w-full text-left px-4 py-2 text-xs font-medium transition-colors ${
                  alt.lang === lang
                    ? 'text-brand bg-brand/10'
                    : 'text-slate-500 dark:text-slate-400 hover:text-brand hover:bg-brand/5 dark:hover:bg-brand/10'
                }`}
              >
                {LANG_LABELS[alt.lang]}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Download CTA (desktop) -->
      <a
        href={APP_LINKS.appStore}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-block text-[0.82rem] font-semibold tracking-[0.01em] px-[1.2rem] py-[0.45rem] bg-slate-900 text-white dark:bg-white dark:text-slate-900 hover:opacity-85 transition-opacity"
      >
        {t(lang, 'nav.download')}
      </a>

      <!-- Theme toggle -->
      <button class="theme-toggle w-9 h-9 rounded-lg border border-slate-300 dark:border-slate-600 bg-transparent cursor-pointer flex items-center justify-center text-slate-500 dark:text-slate-400 hover:text-brand hover:border-brand transition-colors">
        <svg class="sun-icon w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M16.071 16.071l.707.707M7.929 7.929l.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
        <svg class="moon-icon w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <!-- Download CTA (mobile) -->
      <a
        href={APP_LINKS.appStore}
        target="_blank"
        rel="noopener noreferrer"
        class="md:hidden text-[0.82rem] font-semibold tracking-[0.01em] px-[1.2rem] py-[0.45rem] bg-slate-900 text-white dark:bg-white dark:text-slate-900 hover:opacity-85 transition-opacity"
      >
        {t(lang, 'nav.download')}
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  (function () {
    const nav = document.getElementById('site-navbar');
    if (!nav) return;

    const dropdowns = nav.querySelectorAll('.navbar-dropdown');
    const themeToggles = nav.querySelectorAll('.theme-toggle');

    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      nav.style.background = 'rgba(22,22,26,0.82)';
    }

    function updateThemeIcons() {
      const isDark = document.documentElement.classList.contains('dark');
      nav.querySelectorAll('.sun-icon').forEach((el) => el.classList.toggle('hidden', !isDark));
      nav.querySelectorAll('.moon-icon').forEach((el) => el.classList.toggle('hidden', isDark));
    }

    updateThemeIcons();

    themeToggles.forEach((btn) => {
      btn.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        try {
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        } catch {}
        nav.style.background = isDark ? 'rgba(22,22,26,0.82)' : 'rgba(255,255,255,0.82)';
        updateThemeIcons();
      });
    });

    dropdowns.forEach((dropdown) => {
      const btn = dropdown.querySelector('button');
      const menu = dropdown.querySelector('.navbar-dropdown-menu');
      const chevron = dropdown.querySelector('.dropdown-chevron');
      if (!btn || !menu) return;

      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !menu.classList.contains('hidden');

        dropdowns.forEach((d) => {
          const m = d.querySelector('.navbar-dropdown-menu');
          const c = d.querySelector('.dropdown-chevron');
          if (m && m !== menu) {
            m.classList.add('hidden');
            c?.classList.remove('rotate-180');
          }
        });

        menu.classList.toggle('hidden', isOpen);
        chevron?.classList.toggle('rotate-180', !isOpen);
      });
    });

    document.addEventListener('click', (e) => {
      const target = e.target;
      dropdowns.forEach((dropdown) => {
        if (dropdown.contains(target)) return;
        const menu = dropdown.querySelector('.navbar-dropdown-menu');
        const chevron = dropdown.querySelector('.dropdown-chevron');
        menu?.classList.add('hidden');
        chevron?.classList.remove('rotate-180');
      });
    });

    function onScroll() {
      if (window.scrollY > 10) {
        nav.style.boxShadow = '0 1px 0 rgba(0,0,0,0.08)';
        if (document.documentElement.classList.contains('dark')) {
          nav.style.boxShadow = '0 1px 0 rgba(255,255,255,0.06)';
        }
      } else {
        nav.style.boxShadow = 'none';
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
