---
import { FEATURES } from '@/constants';
import { t } from '@/i18n';
import type { Language } from '@/types';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const featureKeys: Record<string, string> = {
  cloud: 'sync',
};
---

<section id="features" class="py-32 bg-[#f5f5f7] dark:bg-[#0d0d0f] transition-colors">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-20 space-y-4">
      <p class="reveal stagger-1 text-brand font-semibold tracking-wide uppercase text-sm">{t(lang, 'features.tag')}</p>
      <h2 class="reveal stagger-2 text-4xl lg:text-5xl font-extrabold text-slate-900 dark:text-white">{t(lang, 'features.title')}</h2>
      <p class="reveal stagger-3 text-lg text-slate-500 dark:text-slate-400 max-w-2xl mx-auto">
        {t(lang, 'features.subtitle')}
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-12 lg:gap-16">
      {
        FEATURES.map((feature, index) => {
          const translationKey = featureKeys[feature.id] || feature.id;
          return (
            <div class={`reveal text-left stagger-${Math.min(index + 1, 6)}`}>
              <div class="w-14 h-14 bg-gradient-to-br from-brand to-emerald-500 rounded-2xl flex items-center justify-center text-white mb-6 shadow-lg shadow-brand/20">
                <div set:html={feature.icon} />
              </div>
              <h3 class="text-xl font-bold mb-3 text-slate-900 dark:text-white">{t(lang, `features.${translationKey}.title`)}</h3>
              <p class="text-lg text-slate-500 dark:text-slate-400 leading-relaxed">
                {t(lang, `features.${translationKey}.description`)}
              </p>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
