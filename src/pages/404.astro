---
// 404 Not Found — proper error page without meta refresh redirect
const SITE = 'https://sugarlite.top';
---

<!DOCTYPE html>
<html lang="zh-CN" class="scroll-smooth" data-theme-handler>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />

    <title>404 - Page Not Found | SugarLite</title>
    <meta name="description" content="The page you're looking for doesn't exist. Navigate to SugarLite homepage to continue." />

    <!-- Dark mode -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>

    <style is:inline>
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: 'Outfit', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        background-color: #f8fafc;
        color: #0f172a;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem;
      }
      .dark body {
        background-color: #020617;
        color: #f1f5f9;
      }
      .logo {
        width: 64px;
        height: 64px;
        border-radius: 14px;
        margin-bottom: 1.5rem;
      }
      h1 {
        font-size: 4rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin: 0;
        line-height: 1;
        color: #00C09A;
      }
      .dark h1 { color: #00D4A8; }
      h2 {
        font-size: 1.25rem;
        font-weight: 600;
        margin: 0.75rem 0 0.5rem;
      }
      p {
        font-size: 0.95rem;
        color: #64748b;
        max-width: 400px;
        margin: 0.5rem 0 2rem;
        line-height: 1.6;
      }
      .dark p { color: #94a3b8; }
      .links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
      }
      .links a {
        padding: 0.6rem 1.2rem;
        font-size: 0.88rem;
        font-weight: 600;
        text-decoration: none;
        border-radius: 8px;
        transition: opacity 0.2s;
      }
      .links a:hover { opacity: 0.85; }
      .btn-primary {
        background: #0f172a;
        color: #fff;
      }
      .dark .btn-primary { background: #f1f5f9; color: #0f172a; }
      .btn-secondary {
        border: 1px solid #cbd5e1;
        color: #475569;
      }
      .dark .btn-secondary { border-color: #475569; color: #94a3b8; }
    </style>

    <link rel="icon" type="image/png" href="/icon.png" />
  </head>
  <body>
    <img src="/icon.png" alt="SugarLite" class="logo" width="64" height="64" />
    <h1>404</h1>
    <h2>Page Not Found</h2>
    <p>Sorry, the page you're looking for doesn't exist or has been moved.</p>
    <div class="links">
      <a href="/" class="btn-primary">返回首页</a>
      <a href="/en" class="btn-secondary">Home</a>
      <a href="/ja" class="btn-secondary">ホーム</a>
      <a href="/zh-Hant" class="btn-secondary">首頁</a>
    </div>
  </body>
</html>
