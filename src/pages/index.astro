---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/sections/Navbar.astro';
import Hero from '@/components/sections/Hero.astro';
import Stats from '@/components/sections/Stats.astro';
import Features from '@/components/sections/Features.astro';
import AppPreview from '@/components/sections/AppPreview.astro';
import SuitableUsers from '@/components/sections/SuitableUsers.astro';
import BlogTeaser from '@/components/sections/BlogTeaser.astro';
import CTA from '@/components/sections/CTA.astro';
import Footer from '@/components/sections/Footer.astro';
import { getAlternateUrls } from '@/i18n/routing';
import {
  buildWebSiteSchema,
  buildOrganizationSchema,
  buildMobileApplicationSchema,
  buildBreadcrumbSchema,
  buildHowToSchema,
} from '@/lib/structuredData';

const lang = 'zh';
const alternates = getAlternateUrls('', 'zh', Astro.url.origin).filter((a) => a.hrefLang !== 'x-default');

const jsonLd = [
  buildWebSiteSchema(lang),
  buildOrganizationSchema(lang),
  buildMobileApplicationSchema(lang),
  buildBreadcrumbSchema(lang, []),
  buildHowToSchema(lang),
];
---

<Layout lang={lang} page="home" jsonLd={jsonLd}>
  <Navbar
    lang={lang}
    alternateUrls={alternates.map((a) => ({ lang: a.hrefLang, href: a.href }))}
  />

  <main>
    <Hero lang={lang} />
    <Stats lang={lang} />
    <Features lang={lang} />
    <AppPreview lang={lang} />
    <SuitableUsers lang={lang} />
    <BlogTeaser lang={lang} />
    <CTA lang={lang} />
  </main>

  <Footer lang={lang} />
</Layout>
