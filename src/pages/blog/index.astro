---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/sections/Navbar.astro';
import Footer from '@/components/sections/Footer.astro';
import BlogIndex from '@/components/sections/BlogIndex.astro';
import { getAlternateUrls } from '@/i18n/routing';
import { buildBreadcrumbSchema } from '@/lib/structuredData';
import { t } from '@/i18n';

const lang = 'zh';
const pathWithoutLang = 'blog';
const alternates = getAlternateUrls(pathWithoutLang, 'zh', Astro.url.origin).filter(
  (a) => a.hrefLang !== 'x-default'
);

const jsonLd = [
  buildBreadcrumbSchema(lang, [{ name: t(lang, 'blog.title'), path: pathWithoutLang }]),
];
---

<Layout lang={lang} page="blog" pathWithoutLang={pathWithoutLang} jsonLd={jsonLd}>
  <Navbar
    lang={lang}
    alternateUrls={alternates.map((a) => ({ lang: a.hrefLang, href: a.href }))}
  />

  <main>
    <BlogIndex lang={lang} />
  </main>

  <Footer lang={lang} />
</Layout>
