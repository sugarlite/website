---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/sections/Navbar.astro';
import Footer from '@/components/sections/Footer.astro';
import BlogIndex from '@/components/sections/BlogIndex.astro';
import { getAlternateUrls, getStaticLangPaths } from '@/i18n/routing';
import { buildBreadcrumbSchema } from '@/lib/structuredData';
import { t } from '@/i18n';
import type { Language } from '@/types';

export function getStaticPaths() {
  return getStaticLangPaths();
}

const { lang } = Astro.params;
const pathWithoutLang = 'blog';
const alternates = getAlternateUrls(pathWithoutLang, 'zh', Astro.url.origin).filter(
  (a) => a.hrefLang !== 'x-default'
);

const jsonLd = [
  buildBreadcrumbSchema(lang as Language, [{ name: t(lang, 'blog.title'), path: pathWithoutLang }]),
];
---

<Layout lang={lang as Language} page="blog" pathWithoutLang={pathWithoutLang} jsonLd={jsonLd}>
  <Navbar
    lang={lang as Language}
    alternateUrls={alternates.map((a) => ({ lang: a.hrefLang as Language, href: a.href }))}
  />

  <main>
    <BlogIndex lang={lang as Language} />
  </main>

  <Footer lang={lang as Language} />
</Layout>
