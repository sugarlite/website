---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/sections/Navbar.astro';
import FAQ from '@/components/sections/FAQ.astro';
import Footer from '@/components/sections/Footer.astro';
import { getAlternateUrls, getStaticLangPaths } from '@/i18n/routing';
import { buildBreadcrumbSchema, buildFAQPageSchema } from '@/lib/structuredData';
import type { Language } from '@/types';

export function getStaticPaths() {
  return getStaticLangPaths();
}

const { lang } = Astro.params;
const pathWithoutLang = 'faq';
const alternates = getAlternateUrls(pathWithoutLang, "zh", Astro.url.origin).filter((a) => a.hrefLang !== 'x-default');

const jsonLd = [
  buildBreadcrumbSchema(lang as Language, [{ name: 'FAQ', path: pathWithoutLang }]),
  buildFAQPageSchema(lang as Language),
];
---

<Layout lang={lang as Language} page="faq" pathWithoutLang={pathWithoutLang} jsonLd={jsonLd}>
  <Navbar
    lang={lang as Language}
    alternateUrls={alternates.map((a) => ({ lang: a.hrefLang as Language, href: a.href }))}
    
  />

  <main>
    <FAQ lang={lang as Language} />
  </main>

  <Footer lang={lang as Language} />
</Layout>
